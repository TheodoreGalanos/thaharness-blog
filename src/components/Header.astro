<!-- ABOUTME: Sticky site header with terminal-style logo, nav links, and theme toggle. -->
<!-- ABOUTME: Left side shows "> The Harness_" prompt, right side has nav links and theme switch. -->
---
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header class="sticky top-0 left-0 right-0 z-50 border-b border-[--color-border]" style="background-color: var(--color-bg);">
	<nav class="page-shell flex items-center justify-between gap-3 h-16 md:h-[4.25rem]">
		<a
			href="/"
			class="flex min-w-0 items-center gap-0 no-underline hover:no-underline"
		>
			<span class="font-heading text-[--color-accent] text-xl font-medium">&gt;&nbsp;</span>
			<span class="font-heading font-medium text-lg sm:text-xl text-[--color-text-primary] tracking-[-0.02em] truncate">The Harness</span>
			<span class="cursor-blink font-heading text-lg sm:text-xl text-[--color-accent] ml-px">_</span>
			<span class="text-[--color-border] mx-2 hidden md:inline">|</span>
			<span class="font-heading text-[0.8125rem] text-[--color-text-secondary] hidden md:inline">Theodoros Galanos</span>
		</a>
		<div class="hidden md:flex items-center gap-2 ml-2">
			<a href="https://x.com/TheodoreGalanos" target="_blank" rel="noopener noreferrer" class="text-[--color-text-tertiary] hover:text-[--color-text-primary] transition-colors duration-250">
				<span class="sr-only">X (Twitter)</span>
				<svg viewBox="0 0 24 24" aria-hidden="true" width="16" height="16" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
			</a>
			<a href="https://www.linkedin.com/in/theodorosgalanos/" target="_blank" rel="noopener noreferrer" class="text-[--color-text-tertiary] hover:text-[--color-text-primary] transition-colors duration-250">
				<span class="sr-only">LinkedIn</span>
				<svg viewBox="0 0 24 24" aria-hidden="true" width="16" height="16" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
			</a>
		</div>

		<div class="flex shrink-0 items-center gap-0.5 md:gap-2">
			<HeaderLink href="/blog">writing</HeaderLink>
			<span class="text-[--color-text-tertiary] text-xs hidden md:inline">&middot;</span>
			<HeaderLink href="/about">about</HeaderLink>
			<span class="text-[--color-text-tertiary] text-xs hidden md:inline">&middot;</span>
			<HeaderLink href="/search">search</HeaderLink>
			<ThemeToggle />
		</div>
	</nav>
</header>
