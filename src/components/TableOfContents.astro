<!-- ABOUTME: Sticky table of contents sidebar for blog posts. -->
<!-- ABOUTME: Highlights current section via IntersectionObserver as the reader scrolls. -->
---
interface Heading {
	depth: number;
	slug: string;
	text: string;
}

interface Props {
	headings: Heading[];
	variant?: 'default' | 'inline';
}

const { headings, variant = 'default' } = Astro.props;

// Only show h2 and h3
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{tocHeadings.length > 0 && (
	<nav class:list={['toc', variant === 'inline' && 'toc-inline']} aria-label="Table of contents">
		<span class="toc-label">On this page</span>
		<ul>
			{tocHeadings.map((heading) => (
				<li class={heading.depth === 3 ? 'toc-indent' : ''}>
					<a href={`#${heading.slug}`} data-toc-link={heading.slug}>
						{heading.text}
					</a>
				</li>
			))}
		</ul>
	</nav>
)}

<style>
	.toc {
		max-height: calc(100vh - 8rem);
		overflow-y: auto;
	}

	.toc-inline {
		max-height: none;
		overflow: visible;
		padding: 1rem;
		border: 1px solid var(--color-border);
		border-radius: 0.75rem;
		background: color-mix(in srgb, var(--color-surface) 88%, transparent);
	}

	.toc-label {
		font-family: var(--font-heading);
		font-size: 0.6875rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--color-text-tertiary);
		display: block;
		margin-bottom: 0.75rem;
	}

	ul {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	li {
		margin-bottom: 0.25rem;
	}

	li.toc-indent {
		padding-left: 0.75rem;
	}

	a {
		font-family: var(--font-heading);
		font-size: 0.75rem;
		line-height: 1.5;
		color: var(--color-text-tertiary);
		text-decoration: none;
		display: block;
		padding: 0.2rem 0;
		padding-left: 0.75rem;
		border-left: 2px solid transparent;
		transition: color 0.2s, border-color 0.2s;
		overflow-wrap: break-word;
		word-break: break-word;
	}

	a:hover {
		color: var(--color-text-secondary);
	}

	.toc-inline ul {
		display: grid;
		gap: 0.125rem;
	}

	.toc-inline a {
		font-size: 0.8125rem;
		padding-top: 0.35rem;
		padding-bottom: 0.35rem;
	}

	@media (max-width: 768px) {
		.toc-inline {
			padding: 0.875rem;
		}

		.toc-inline a {
			font-size: 0.75rem;
		}
	}

	/* Active state applied via JS */
	a:global(.toc-active) {
		color: var(--color-accent);
		border-left-color: var(--color-accent);
	}
</style>

<script>
	function initToc() {
		const links = document.querySelectorAll('[data-toc-link]');
		if (!links.length) return;

		const slugs = Array.from(links).map((l) => (l as HTMLElement).dataset.tocLink!);
		const targets = slugs
			.map((slug) => document.getElementById(slug))
			.filter(Boolean) as HTMLElement[];

		if (!targets.length) return;

		let activeSlug = '';

		const observer = new IntersectionObserver(
			(entries) => {
				// Find the topmost visible heading
				const visible = entries.filter((e) => e.isIntersecting);
				if (visible.length > 0) {
					// Pick the one closest to the top of the viewport
					const sorted = visible.sort(
						(a, b) => a.boundingClientRect.top - b.boundingClientRect.top,
					);
					const slug = sorted[0].target.id;
					if (slug !== activeSlug) {
						activeSlug = slug;
						links.forEach((link) => {
							const linkSlug = (link as HTMLElement).dataset.tocLink;
							const isActive = linkSlug === slug;
							link.classList.toggle('toc-active', isActive);
							if (isActive) {
								const tocContainer = (link as HTMLElement).closest('.toc');
								if (tocContainer && !tocContainer.classList.contains('toc-inline')) {
									(link as HTMLElement).scrollIntoView({
										block: 'nearest',
										inline: 'nearest',
										behavior: 'smooth',
									});
								}
							}
						});
					}
				}
			},
			{
				rootMargin: '-80px 0px -60% 0px',
				threshold: 0,
			},
		);

		targets.forEach((el) => observer.observe(el));
	}

	// Run on initial load and on Astro page transitions
	initToc();
	document.addEventListener('astro:after-swap', initToc);
</script>
