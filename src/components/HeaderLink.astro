<!-- ABOUTME: Navigation link component that highlights the active route. -->
<!-- ABOUTME: Used in the Header to render nav items with monospace terminal styling. -->
---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '');
const subpath = pathname.match(/[^\/]+/g);
const isActive = href === pathname || href === '/' + (subpath?.[0] || '');
---

<a
	href={href}
	aria-current={isActive ? 'page' : undefined}
	class:list={[
		'header-link inline-flex items-center font-heading text-[0.75rem] sm:text-[0.8125rem] font-normal px-1.5 sm:px-2 py-2 transition-colors duration-250',
		isActive
			? 'text-[--color-accent]'
			: 'text-[--color-text-secondary] hover:text-[--color-text-primary]',
		className,
	]}
	{...props}
>
	{isActive && <span aria-hidden="true" class="header-link-cursor">&gt;</span>}<slot />
</a>

<style>
	.header-link-cursor {
		color: var(--color-accent-secondary);
		margin-right: 0.3em;
		font-weight: 500;
	}
</style>
