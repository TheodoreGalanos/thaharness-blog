<!-- ABOUTME: Editorial meandering-flow diagram for the AEC-Bench trainable loop. -->
<!-- ABOUTME: Renders compact snake-like rows so long process chains fit the prose column. -->
---
import type { TrainableLoopRow } from '../../data/trainable-loop-flow';

interface Props {
	title?: string;
	rows: TrainableLoopRow[];
	caption?: string;
}

interface LayoutStep {
	key: string;
	kicker: string;
	label: string;
	detail: string;
	column: number;
	number: string;
	hasNext: boolean;
}

interface LayoutRow {
	key: string;
	direction: 'forward' | 'reverse';
	steps: LayoutStep[];
	lineLeft: string;
	lineRight: string;
	turnColumn: number;
	hasTurn: boolean;
}

const { title, rows, caption } = Astro.props;

function startColumnFor(row: TrainableLoopRow, rowIndex: number): number {
	void rowIndex;
	if (row.direction === 'reverse') return 3;
	return 1;
}

function formatPercent(value: number): string {
	return `${value.toFixed(4)}%`;
}

let ordinal = 0;
const layoutRows: LayoutRow[] = rows.map((row, rowIndex) => {
	const startColumn = startColumnFor(row, rowIndex);
	const steps = row.steps.map((step, stepIndex) => {
		const column =
			row.direction === 'reverse'
				? startColumn - stepIndex
				: startColumn + stepIndex;
		ordinal += 1;
		return {
			...step,
			column,
			number: String(ordinal).padStart(2, '0'),
			hasNext: stepIndex < row.steps.length - 1,
		};
	});
	const columns = steps.map((step) => step.column);
	const minColumn = Math.min(...columns);
	const maxColumn = Math.max(...columns);
	const lineLeft = formatPercent(((minColumn - 0.5) / 3) * 100);
	const lineRight = formatPercent(100 - ((maxColumn - 0.5) / 3) * 100);
	const lastStep = steps.at(-1);

	return {
		key: row.key,
		direction: row.direction,
		steps,
		lineLeft,
		lineRight,
		turnColumn: lastStep?.column ?? 1,
		hasTurn: rowIndex < rows.length - 1,
	};
});
---

<figure class="tld" aria-label={title ?? 'Trainable loop diagram'}>
	{title && <div class="tld-title">{title}</div>}

	<ol class="tld-rows">
		{layoutRows.map((row) => (
			<li class="tld-row-wrap">
				<ol
					class="tld-row"
					data-direction={row.direction}
					style={`--tld-line-left: ${row.lineLeft}; --tld-line-right: ${row.lineRight};`}
				>
					{row.steps.map((step) => (
						<li
							class:list={['tld-step', step.hasNext && 'has-next']}
							style={`--tld-col: ${step.column};`}
						>
							<span class="tld-step-number">{step.number}</span>
							<span class="tld-step-kicker">{step.kicker}</span>
							<span class="tld-step-label">{step.label}</span>
							<span class="tld-step-detail">{step.detail}</span>
						</li>
					))}
				</ol>
				{row.hasTurn && (
					<div class="tld-turn" aria-hidden="true" style={`--tld-turn-col: ${row.turnColumn};`}>
						<span class="tld-turn-line"></span>
					</div>
				)}
			</li>
		))}
	</ol>

	{caption && <figcaption class="tld-caption">{caption}</figcaption>}
</figure>

<style>
	.tld {
		--tld-accent: var(--color-accent);
		--tld-secondary: var(--color-accent-secondary);
		--tld-rail: color-mix(in srgb, var(--color-accent-secondary) 44%, var(--color-border));
		--tld-card-bg: color-mix(in srgb, var(--color-surface) 88%, transparent);

		margin: 3rem 0;
		font-family: var(--font-body);
		color: var(--color-text-primary);
		text-align: left;
	}

	.tld-title {
		font-family: var(--font-mono);
		font-size: 0.6875rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: var(--color-accent);
		margin: 0 0 1.25rem;
	}

	.tld-rows,
	.tld-row {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.tld-rows {
		display: grid;
		gap: 0;
	}

	.tld-row {
		position: relative;
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.75rem;
		align-items: stretch;
	}

	.tld-row::before,
	.tld-row::after {
		content: '';
		position: absolute;
		top: 50%;
		z-index: 0;
		pointer-events: none;
	}

	.tld-row::before {
		left: var(--tld-line-left);
		right: var(--tld-line-right);
		height: 1px;
		background: linear-gradient(
			90deg,
			transparent,
			var(--tld-rail) 14%,
			var(--tld-rail) 86%,
			transparent
		);
	}

	.tld-row[data-direction='forward']::after {
		right: var(--tld-line-right);
		width: 0;
		height: 0;
		margin-top: -4px;
		border-top: 4px solid transparent;
		border-bottom: 4px solid transparent;
		border-left: 7px solid var(--tld-rail);
	}

	.tld-row[data-direction='reverse']::after {
		left: var(--tld-line-left);
		width: 0;
		height: 0;
		margin-top: -4px;
		border-top: 4px solid transparent;
		border-bottom: 4px solid transparent;
		border-right: 7px solid var(--tld-rail);
	}

	.tld-step {
		position: relative;
		z-index: 1;
		grid-column: var(--tld-col);
		grid-row: 1;
		min-height: 8.25rem;
		display: grid;
		grid-template-rows: auto auto auto 1fr;
		gap: 0.35rem;
		padding: 0.9rem 0.95rem 0.95rem;
		border: 1px solid var(--color-border);
		border-radius: 6px;
		background:
			linear-gradient(135deg, color-mix(in srgb, var(--tld-secondary) 8%, transparent), transparent 42%),
			var(--tld-card-bg);
		box-shadow: 0 10px 26px rgba(0, 0, 0, 0.12);
		overflow: hidden;
	}

	.tld-step::before {
		content: '';
		position: absolute;
		inset: 0 auto 0 0;
		width: 2px;
		background: var(--tld-secondary);
		opacity: 0.72;
	}

	.tld-step:nth-child(3n + 1)::before {
		background: var(--tld-accent);
	}

	.tld-step-number {
		position: absolute;
		top: 0.75rem;
		right: 0.8rem;
		font-family: var(--font-mono);
		font-size: 0.625rem;
		letter-spacing: 0.12em;
		color: var(--color-text-tertiary);
	}

	.tld-step-kicker {
		padding-right: 2rem;
		font-family: var(--font-mono);
		font-size: 0.625rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-text-tertiary);
	}

	.tld-step-label {
		font-family: var(--font-mono);
		font-size: 0.875rem;
		font-weight: 500;
		letter-spacing: 0.02em;
		color: var(--color-text-primary);
	}

	.tld-step-detail {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		line-height: 1.5;
		color: var(--color-text-secondary);
	}

	.tld-turn {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.75rem;
		height: 2.25rem;
	}

	.tld-turn-line {
		position: relative;
		grid-column: var(--tld-turn-col);
		justify-self: center;
		width: 1px;
		height: 100%;
		background: var(--tld-rail);
	}

	.tld-turn-line::after {
		content: '';
		position: absolute;
		left: 50%;
		bottom: 0;
		width: 0;
		height: 0;
		transform: translateX(-50%);
		border-left: 4px solid transparent;
		border-right: 4px solid transparent;
		border-top: 7px solid var(--tld-rail);
	}

	.tld-caption {
		margin-top: 1.5rem;
		padding-top: 1rem;
		border-top: 1px solid var(--color-border);
		font-family: var(--font-mono);
		font-size: 0.8125rem;
		color: var(--color-text-tertiary);
		line-height: 1.55;
		font-style: normal;
		text-align: left;
	}

	@media (max-width: 760px) {
		.tld-row {
			grid-template-columns: 1fr;
			gap: 0.65rem;
		}

		.tld-row::before,
		.tld-row::after {
			display: none;
		}

		.tld-step {
			grid-column: 1;
			min-height: 0;
		}

		.tld-step.has-next::after {
			content: '';
			position: absolute;
			left: 1.25rem;
			bottom: -0.65rem;
			width: 1px;
			height: 0.65rem;
			background: var(--tld-rail);
		}

		.tld-turn {
			grid-template-columns: 1fr;
			height: 1.2rem;
			gap: 0;
		}

		.tld-turn-line {
			grid-column: 1;
			justify-self: start;
			margin-left: 1.25rem;
		}
	}
</style>
