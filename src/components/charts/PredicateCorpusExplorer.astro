		text-transform: uppercase;
		letter-spacing: 0.14em;
	}

	.pe-panel-supersedes-value {
		color: var(--color-text-secondary);
	}

	.pe-tabs {
		display: flex;
		flex-wrap: wrap;
		gap: 0;
		padding: 0 1rem;
		border-bottom: 1px solid var(--color-border);
		background: color-mix(in srgb, var(--color-bg) 30%, var(--color-surface));
	}

	.pe-tab {
		padding: 0.55rem 0.85rem;
		border: none;
		background: transparent;
		font-family: var(--font-mono);
		font-size: 0.7rem;
		letter-spacing: 0.04em;
		color: var(--color-text-tertiary);
		cursor: pointer;
		border-bottom: 2px solid transparent;
		margin-bottom: -1px;
		transition: color 0.18s var(--ease-standard), border-color 0.18s var(--ease-standard);
	}

	.pe-tab:hover,
	.pe-tab:focus-visible {
		color: var(--color-text-primary);
		outline: none;
	}

	.pe-tab.is-active {
		color: var(--color-text-primary);
		border-bottom-color: var(--color-accent);
	}

	.pe-panes {
		position: relative;
		min-height: 11rem;
	}

	.pe-pane {
		margin: 0;
		padding: 0;
		font-family: var(--font-mono);
		font-size: 0.78rem;
		line-height: 1.55;
		color: var(--color-text-primary);
		background: transparent;
		overflow-x: auto;
	}

	/* Let Shiki's generated <pre> inherit our panel styling rather than its
	   own (often white-on-#0d1117) defaults. */
	.pe-pane :global(pre.astro-code) {
		margin: 0;
		padding: 1rem 1rem 1.1rem;
		background: transparent !important;
		font-family: inherit;
		font-size: inherit;
		line-height: inherit;
		white-space: pre;
		overflow-x: auto;
	}

	.pe-pane :global(pre.astro-code code) {
		font-family: inherit;
		font-size: inherit;
		line-height: inherit;
		background: transparent;
		padding: 0;
	}

	.pe-empty {
		padding: 1.5rem 1rem;
		font-family: var(--font-mono);
		font-size: 0.8rem;
		color: var(--color-text-tertiary);
	}

	.pe-validate {
		border-top: 1px solid var(--color-border);
		padding: 0.65rem 1rem 0.85rem;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		background: color-mix(in srgb, var(--color-bg) 30%, var(--color-surface));
	}

	.pe-validate-button {
		align-self: flex-start;
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.4rem 0.7rem;
		border: 1px solid var(--color-border);
		border-radius: 3px;
		background: var(--color-surface);
		color: var(--color-text-primary);
		font-family: var(--font-mono);
		font-size: 0.72rem;
		letter-spacing: 0.04em;
		cursor: pointer;
		transition:
			background 0.18s var(--ease-standard),
			border-color 0.18s var(--ease-standard);
	}

	.pe-validate-button:hover,
	.pe-validate-button:focus-visible {
		border-color: var(--color-accent);
		outline: none;
	}

	.pe-validate-button.is-running .pe-validate-label::after {
		content: ' …running';
		color: var(--color-text-tertiary);
	}

	.pe-validate-prompt {
		color: var(--color-accent);
	}

	.pe-validate-output {
		margin: 0;
		padding: 0.75rem 0.85rem;
		font-family: var(--font-mono);
		font-size: 0.72rem;
		line-height: 1.6;
		color: var(--color-text-primary);
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: 3px;
		white-space: pre;
		overflow-x: auto;
	}

	.pe-validate-output code {
		color: inherit;
	}

	.pe-caption {
		margin-top: 1.25rem;
		padding-top: 1rem;
		border-top: 1px solid var(--color-border);
		font-family: var(--font-mono);
		font-size: 0.8125rem;
		color: var(--color-text-tertiary);
		line-height: 1.55;
		font-style: normal;
	}
</style>

<script>
	(() => {
		const roots = document.querySelectorAll<HTMLElement>('[data-pe-root]');
		roots.forEach((root) => {
			const versionButtons = root.querySelectorAll<HTMLButtonElement>('[data-pe-version]');
			const predicateButtons = root.querySelectorAll<HTMLButtonElement>('[data-pe-predicate]');
			const tabButtons = root.querySelectorAll<HTMLButtonElement>('[data-pe-tab]');
			const panes = root.querySelectorAll<HTMLElement>('[data-pe-pane]');
			const empty = root.querySelector<HTMLElement>('[data-pe-empty]');
			const nameEl = root.querySelector<HTMLElement>('[data-pe-predicate-name]');
			const statusEl = root.querySelector<HTMLElement>('[data-pe-status]');
			const supersedesEl = root.querySelector<HTMLElement>('[data-pe-supersedes]');
			const supersedesValEl = root.querySelector<HTMLElement>('[data-pe-supersedes-value]');

			const state = {
				version: root.dataset.defaultVersion ?? '',
				predicate: root.dataset.defaultPredicate ?? '',
				tab: 'predicate.py',
			};

			function findPaneFor(predicate: string, version: string, tab: string) {
				for (const pane of Array.from(panes)) {
					if (
						pane.dataset.predicate === predicate &&
						pane.dataset.version === version &&
						pane.dataset.tab === tab
					) {
						return pane;
					}
				}
				return null;
			}

			function availableTabs(predicate: string, version: string) {
				const tabs: string[] = [];
				panes.forEach((p) => {
					if (
						p.dataset.predicate === predicate &&
						p.dataset.version === version &&
						p.dataset.tab
					) {
						tabs.push(p.dataset.tab);
					}
				});
				return tabs;
			}

			function render() {
				// Panes
				panes.forEach((p) => p.setAttribute('hidden', ''));
				const target = findPaneFor(state.predicate, state.version, state.tab);
				if (target) {
					target.removeAttribute('hidden');
					empty?.setAttribute('hidden', '');
					if (statusEl) {
						const st = target.dataset.status ?? 'released';
						statusEl.textContent = st;
						statusEl.dataset.status = st;
					}
					const sup = target.dataset.supersedes ?? '';
					if (supersedesEl && supersedesValEl) {
						if (sup) {
							supersedesValEl.textContent = sup;
							supersedesEl.removeAttribute('hidden');
						} else {
							supersedesEl.setAttribute('hidden', '');
						}
					}
				} else {
					empty?.removeAttribute('hidden');
					supersedesEl?.setAttribute('hidden', '');
				}

				// Predicate buttons
				predicateButtons.forEach((b) => {
					b.classList.toggle('is-active', b.dataset.pePredicate === state.predicate);
				});
				if (nameEl) {
					const active = Array.from(predicateButtons).find(
						(b) => b.dataset.pePredicate === state.predicate,
					);
					nameEl.textContent =
						active?.querySelector('.pe-tree-label')?.textContent ?? state.predicate;
				}

				// Tabs availability + active state
				const tabs = availableTabs(state.predicate, state.version);
				tabButtons.forEach((b) => {
					const tab = b.dataset.peTab ?? '';
					const enabled = tabs.includes(tab);
					b.toggleAttribute('disabled', !enabled);
					b.style.opacity = enabled ? '' : '0.35';
					b.style.cursor = enabled ? '' : 'not-allowed';
					b.classList.toggle('is-active', tab === state.tab && enabled);
				});

				// Version buttons
				versionButtons.forEach((b) => {
					const active = b.dataset.peVersion === state.version;
					b.classList.toggle('is-active', active);
					b.setAttribute('aria-selected', active ? 'true' : 'false');
				});
			}

			versionButtons.forEach((b) => {
				b.addEventListener('click', () => {
					if (!b.dataset.peVersion) return;
					state.version = b.dataset.peVersion;
					// If predicate not in this version, fall back to first tab; render handles empty.
					render();
				});
			});

			predicateButtons.forEach((b) => {
				b.addEventListener('click', () => {
					if (!b.dataset.pePredicate) return;
					state.predicate = b.dataset.pePredicate;
					// Reset to predicate.py if available, otherwise first.
					const tabs = availableTabs(state.predicate, state.version);
					if (tabs.length && !tabs.includes(state.tab)) state.tab = tabs[0];
					render();
				});
			});

			tabButtons.forEach((b) => {
				b.addEventListener('click', () => {
					if (b.hasAttribute('disabled')) return;
					if (!b.dataset.peTab) return;
					state.tab = b.dataset.peTab;
					render();
				});
			});

			const validateButton = root.querySelector<HTMLButtonElement>('[data-pe-validate]');
			const validateOutput = root.querySelector<HTMLElement>('[data-pe-validate-output]');
			validateButton?.addEventListener('click', () => {
				if (!validateOutput) return;
				const isOpen = !validateOutput.hasAttribute('hidden');
				if (isOpen) {
					validateOutput.setAttribute('hidden', '');
					validateButton.classList.remove('is-running');
					return;
				}
				validateButton.classList.add('is-running');
				window.setTimeout(() => {
					validateOutput.removeAttribute('hidden');
					validateButton.classList.remove('is-running');
				}, 320);
			});

			render();
		});
	})();
</script>
