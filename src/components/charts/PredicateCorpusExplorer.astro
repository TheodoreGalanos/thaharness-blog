<!-- ABOUTME: Editorial predicate-corpus explorer — file-tree on the left, tabbed artefact panel on the right. -->
<!-- ABOUTME: Click a predicate to inspect, switch tabs, toggle standard amendment to reveal supersession edges. -->
---
import { Code } from 'astro:components';

export interface CorpusVersion {
	key: string;
	label: string;
	default?: boolean;
}

export interface CorpusTreeNode {
	key: string;
	label: string;
	children?: CorpusTreeNode[];
	isLeaf?: boolean;
	featured?: boolean;
}

export interface CorpusPredicateVersion {
	status: 'released' | 'draft' | 'audited' | 'deprecated' | 'rejected';
	supersedes?: string | null;
	tabs: Record<string, string>;
}

export interface CorpusPredicate {
	label: string;
	status: string;
	versions: Record<string, CorpusPredicateVersion>;
}

interface Props {
	title?: string;
	subtitle?: string;
	versions: CorpusVersion[];
	tree: CorpusTreeNode[];
	predicates: Record<string, CorpusPredicate>;
	defaultPredicate: string;
	caption?: string;
}

const {
	title,
	subtitle,
	versions,
	tree,
	predicates,
	defaultPredicate,
	caption,
} = Astro.props;

const TAB_ORDER = ['predicate.py', 'tests.py', 'manifest.json', 'provenance.json'] as const;

function langFor(tab: string): 'python' | 'json' | 'text' {
	if (tab.endsWith('.py')) return 'python';
	if (tab.endsWith('.json')) return 'json';
	return 'text';
}

function flattenTree(nodes: CorpusTreeNode[], depth = 0): Array<CorpusTreeNode & { depth: number }> {
	const out: Array<CorpusTreeNode & { depth: number }> = [];
	for (const n of nodes) {
		out.push({ ...n, depth });
		if (n.children) out.push(...flattenTree(n.children, depth + 1));
	}
	return out;
}
const flatNodes = flattenTree(tree);
const defaultVersion = versions.find((v) => v.default)?.key ?? versions[0].key;

// Pre-render every predicate × version × tab combination as hidden panels.
type Pane = {
	predicateKey: string;
	versionKey: string;
	tabKey: string;
	status: string;
	supersedes: string | null;
	code: string;
};
const panes: Pane[] = [];
for (const [predKey, pred] of Object.entries(predicates)) {
	for (const [verKey, ver] of Object.entries(pred.versions)) {
		for (const tabKey of TAB_ORDER) {
			if (!(tabKey in ver.tabs)) continue;
			panes.push({
				predicateKey: predKey,
				versionKey: verKey,
				tabKey,
				status: ver.status,
				supersedes: ver.supersedes ?? null,
				code: ver.tabs[tabKey],
			});
		}
	}
}

---

<figure class="pe" data-pe-root data-default-version={defaultVersion} data-default-predicate={defaultPredicate}>
	{title && (
		<div class="pe-title">
			{title}
			{subtitle && <span class="pe-subtitle"> · {subtitle}</span>}
		</div>
	)}

	<div class="pe-toolbar">
		<div class="pe-toolbar-label">Standard version</div>
		<div class="pe-version-toggle" role="tablist">
			{versions.map((v) => (
				<button
					type="button"
					class={`pe-version${v.key === defaultVersion ? ' is-active' : ''}`}
					data-pe-version={v.key}
					role="tab"
					aria-selected={v.key === defaultVersion ? 'true' : 'false'}
				>
					{v.label}
				</button>
			))}
		</div>
	</div>

	<div class="pe-body">
		<aside class="pe-tree" aria-label="Corpus tree">
			<div class="pe-tree-head">specs/</div>
			<ul class="pe-tree-list">
				{flatNodes.map((node) => (
					<li
						class={[
							'pe-tree-node',
							node.isLeaf ? 'is-leaf' : 'is-branch',
						].join(' ')}
						style={`--pe-depth: ${node.depth};`}
					>
						{node.isLeaf ? (
							<button
								type="button"
								class={`pe-tree-leaf${node.key === defaultPredicate ? ' is-active' : ''}`}
								data-pe-predicate={node.key}
								data-pe-available-versions={Object.keys(predicates[node.key]?.versions ?? {}).join(',')}
							>
								<span class="pe-tree-icon" aria-hidden="true">›</span>
								<span class="pe-tree-label">{node.label}</span>
								{node.featured && <span class="pe-tree-pin" aria-hidden="true">★</span>}
							</button>
						) : (
							<div class="pe-tree-branch">
								<span class="pe-tree-icon" aria-hidden="true">▾</span>
								<span class="pe-tree-label">{node.label}/</span>
							</div>
						)}
					</li>
				))}
			</ul>
		</aside>

		<section class="pe-panel">
			<header class="pe-panel-head">
				<div class="pe-panel-title">
					<span class="pe-panel-name" data-pe-predicate-name>{predicates[defaultPredicate]?.label ?? ''}</span>
					<span class="pe-panel-status" data-pe-status>released</span>
				</div>
				<div class="pe-panel-supersedes" data-pe-supersedes hidden>
					<span class="pe-panel-supersedes-kicker">supersedes</span>
					<span class="pe-panel-supersedes-value" data-pe-supersedes-value></span>
				</div>
			</header>

			<div class="pe-tabs" role="tablist">
				{TAB_ORDER.map((tab) => (
					<button
						type="button"
						class="pe-tab"
						data-pe-tab={tab}
						role="tab"
					>
						{tab}
					</button>
				))}
			</div>

			<div class="pe-panes">
				{panes.map((p, idx) => (
					<div
						class="pe-pane"
						data-pe-pane
						data-predicate={p.predicateKey}
						data-version={p.versionKey}
						data-tab={p.tabKey}
						data-status={p.status}
						data-supersedes={p.supersedes ?? ''}
						hidden={idx !== 0}
					>
						<Code code={p.code} lang={langFor(p.tabKey)} />
					</div>
				))}
				<div class="pe-empty" data-pe-empty hidden>
					Not available in this amendment.
				</div>
			</div>

			<div class="pe-validate">
				<button type="button" class="pe-validate-button" data-pe-validate>
					<span class="pe-validate-prompt" aria-hidden="true">$</span>
					<span class="pe-validate-label">corpus validate</span>
				</button>
				<pre class="pe-validate-output" data-pe-validate-output hidden><code>{`✓ required files present
✓ predicate tests pass
✓ hashes fresh
✓ released hash unique
✓ indexes match manifests
✓ no unresolved supersession conflicts`}</code></pre>
			</div>
		</section>
	</div>

	{caption && <figcaption class="pe-caption">{caption}</figcaption>}
</figure>

<style>
	.pe {
		margin: 3rem 0;
		font-family: var(--font-body);
		color: var(--color-text-primary);
	}

	.pe-title {
		font-family: var(--font-mono);
		font-size: 0.6875rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: var(--color-accent);
		margin: 0 0 1rem;
	}

