<!-- ABOUTME: Editorial failure-fingerprint bars — verifier fields ranked by how many trials lost them. -->
<!-- ABOUTME: Wide mono label column, "n / N" counts, one highlight; shared right-gutter hover panel. -->
---
export interface FailureBar {
	key: string;
	label: string;
	failed: number;
	note?: string;
	highlight?: boolean;
}

interface Props {
	title?: string;
	subtitle?: string;
	total: number;
	bars: FailureBar[];
	caption?: string;
}

const { title, subtitle, total, bars, caption } = Astro.props;

function pct(failed: number): number {
	if (total <= 0) return 0;
	return Math.min(Math.max(failed / total, 0), 1) * 100;
}

const BAR_ACCENT = '#9a958c';
const HIGHLIGHT_ACCENT = '#bf4d43';
---

<figure class="fb" data-fb-root>
	{title && (
		<div class="fb-title">
			{title}
			{subtitle && <span class="fb-subtitle"> · {subtitle}</span>}
		</div>
	)}

	<div class="fb-body">
		<aside class="fb-panel" aria-live="polite">
			<div class="fb-panel-sticky">
				<div class="fb-panel-inner">
					<span class="fb-panel-kicker" data-fb-kicker></span>
					<span class="fb-panel-body" data-fb-body></span>
				</div>
			</div>
		</aside>

		<ol class="fb-bars">
			{bars.map((b) => {
				const fill = pct(b.failed);
				const accent = b.highlight ? HIGHLIGHT_ACCENT : BAR_ACCENT;
				return (
					<li
						class:list={['fb-row', { 'is-highlight': b.highlight }]}
						data-fb-bar
						data-label={b.label}
						data-failed={String(b.failed)}
						data-total={String(total)}
						data-note={b.note ?? ''}
						style={`--fb-accent: ${accent};`}
						tabindex="0"
						aria-label={`${b.label}: failed in ${b.failed} of ${total} trials`}
					>
						<span class="fb-label">{b.label}</span>
						<span class="fb-track" aria-hidden="true">
							<span class="fb-fill" style={`width: ${fill}%;`}></span>
						</span>
						<span class="fb-value">{b.failed}&thinsp;/&thinsp;{total}</span>
					</li>
				);
			})}
		</ol>
	</div>

	{caption && <figcaption class="fb-caption">{caption}</figcaption>}
</figure>

<style>
	.fb {
		--fb-sticky-top: 8rem;
		--fb-track-bg: color-mix(in srgb, var(--color-border) 70%, transparent);
		position: relative;
		margin: 3rem 0;
		font-family: var(--font-body);
		color: var(--color-text-primary);
	}

	.fb-title {
		font-family: var(--font-mono);
		font-size: 0.6875rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: var(--color-accent);
		margin: 0 0 1.25rem;
	}

	.fb-subtitle {
		color: var(--color-text-tertiary);
		font-weight: 400;
	}

	.fb-body {
		position: relative;
	}

	.fb-bars {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 0.5rem;
	}

	.fb-row {
		display: grid;
		grid-template-columns: minmax(9rem, 15rem) 1fr 3.5rem;
		align-items: center;
		gap: 0.75rem;
		padding: 0.25rem 0.4rem;
		border-radius: 3px;
		cursor: pointer;
		transition: background-color 0.2s var(--ease-standard);
	}

	.fb-row:hover,
	.fb-row:focus-visible {
		background: color-mix(in srgb, var(--fb-accent) 12%, transparent);
		outline: none;
	}

	.fb-label {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		letter-spacing: 0.02em;
		color: var(--color-text-secondary);
		overflow-wrap: anywhere;
	}

	.fb-row:hover .fb-label,
	.fb-row:focus-visible .fb-label,
	.fb-row.is-highlight .fb-label {
		color: var(--color-text-primary);
	}

	.fb-track {
		position: relative;
		display: block;
		height: 0.95rem;
		background: var(--fb-track-bg);
		border-radius: 2px;
		overflow: hidden;
	}

	.fb-fill {
		display: block;
		height: 100%;
		background: var(--fb-accent);
		border-radius: 2px;
		transition: filter 0.2s var(--ease-standard);
	}

	.fb-row:hover .fb-fill,
	.fb-row:focus-visible .fb-fill {
		filter: brightness(1.1);
	}

	.fb-value {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		color: var(--color-text-tertiary);
		text-align: right;
	}

	.fb-row.is-highlight .fb-value {
		color: var(--fb-accent);
	}

	.fb-caption {
		margin-top: 1.5rem;
		padding-top: 1rem;
		border-top: 1px solid var(--color-border);
		font-family: var(--font-mono);
		font-size: 0.8125rem;
		color: var(--color-text-tertiary);
		line-height: 1.55;
		font-style: normal;
	}

	@media (max-width: 640px) {
		.fb-row {
			grid-template-columns: minmax(7rem, 1fr) 1fr 3rem;
			gap: 0.5rem;
		}
	}
</style>

<script>
	import { createChartHoverPanel } from '../../scripts/chart-hover-panel';

	(() => {
		const roots = document.querySelectorAll<HTMLElement>('[data-fb-root]');
		roots.forEach((root) => {
			const panel = createChartHoverPanel(root, '[data-fb-kicker]', '[data-fb-body]');
			if (!panel) return;

			const bars = root.querySelectorAll<HTMLElement>('[data-fb-bar]');
			bars.forEach((bar) => {
				const show = () => {
					const label = bar.dataset.label ?? '';
					const failed = bar.dataset.failed ?? '';
					const total = bar.dataset.total ?? '';
					const note = bar.dataset.note ?? '';
					panel.set(`${label} · ${failed}/${total}`, note);
				};
				panel.bind(bar, show);
			});
		});
	})();
</script>
