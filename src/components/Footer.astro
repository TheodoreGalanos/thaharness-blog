			<p class="mb-0 font-mono text-[0.75rem] leading-relaxed text-[--color-text-tertiary]">
				&copy; {today.getFullYear()} Theodoros Galanos &middot; The Harness
			</p>
			<div class="flex items-center gap-5 font-mono text-[0.75rem] text-[--color-text-tertiary]">
				<a href="/subscribe" class="text-[--color-text-tertiary] hover:text-[--color-text-primary] transition-colors duration-250">subscribe</a>
				<a href="/rss.xml" class="text-[--color-text-tertiary] hover:text-[--color-text-primary] transition-colors duration-250">RSS</a>
				<a href="https://github.com/theodoros-galanos" class="text-[--color-text-tertiary] hover:text-[--color-text-primary] transition-colors duration-250">GitHub</a>
				<a href="https://x.com/TheodoreGalanos" target="_blank" rel="noopener noreferrer" class="text-[--color-text-tertiary] hover:text-[--color-text-primary] transition-colors duration-250 inline-flex items-center" aria-label="X (Twitter)">
					<svg viewBox="0 0 24 24" aria-hidden="true" width="14" height="14" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
