<!-- ABOUTME: Blog archive page listing every published article as a year-grouped editorial list. -->
<!-- ABOUTME: Chronological, hairline-separated; featured posts get a slightly larger treatment inside their year. -->
---
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import { getPublishedBlogPosts } from '../../utils/blog';

const posts = getPublishedBlogPosts(await getCollection('blog'));

const postsByYear = posts.reduce<Record<number, typeof posts>>((acc, post) => {
	const year = post.data.pubDate.getFullYear();
	if (!acc[year]) acc[year] = [];
	acc[year].push(post);
	return acc;
}, {});

const sortedYears = Object.keys(postsByYear)
	.map(Number)
	.sort((a, b) => b - a);
---

<!doctype html>
<html lang="en" data-theme="dark">
	<head>
		<BaseHead title={`Articles on Harness Engineering & Agentic AI in AEC | ${SITE_TITLE}`} description="Articles on harness engineering, agent evaluation, and building reliable AI systems for architecture, engineering, and construction (AEC) work." />
	</head>
	<body class="bg-[--color-bg]">
		<Header />
		<main class="px-6 py-16 md:py-24">
			<div class="mx-auto max-w-[50rem]">
				<header class="archive-header">
					<span class="archive-kicker">Archive</span>
					<h1 class="archive-headline">Writing</h1>
					<p class="archive-deck">
						Notes on harness engineering, agent evaluation, and building reliable AI systems for real engineering work.
					</p>
				</header>

				{sortedYears.map((year) => (
					<section class="archive-year">
						<header class="archive-year-header">
							<span class="archive-year-label">{year}</span>
							<span class="archive-year-count">
								{postsByYear[year].length} {postsByYear[year].length === 1 ? 'piece' : 'pieces'}
							</span>
						</header>
						<ol class="archive-list" role="list">
							{postsByYear[year].map((post) => (
								<li class={`archive-item${post.data.featured ? ' is-featured' : ''}`}>
									<a href={`/blog/${post.id}/`} class="archive-link">
										<div class="archive-meta">
											<FormattedDate date={post.data.pubDate} />
											{post.data.featured && (
												<span class="archive-featured">Featured</span>
											)}
										</div>
										<h2 class="archive-title">{post.data.title}</h2>
										<p class="archive-description">{post.data.description}</p>
										{post.data.tags.length > 0 && (
											<div class="archive-tags">
												{post.data.tags.slice(0, 4).map((tag: string) => (
													<span class="archive-tag">{tag}</span>
												))}
											</div>
										)}
									</a>
								</li>
							))}
						</ol>
					</section>
				))}
			</div>
		</main>
		<Footer />
		<Analytics />
		<SpeedInsights />
	</body>
</html>

<style>
	.archive-header {
		margin-bottom: 4rem;
	}

	.archive-kicker {
		display: inline-block;
		font-family: var(--font-mono);
		font-size: 0.6875rem;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: var(--color-accent);
		margin-bottom: 1.25rem;
	}

	.archive-headline {
		font-family: var(--font-display);
		font-weight: 500;
		font-size: clamp(2.5rem, 5.5vw, 4rem);
		line-height: 1.05;
		letter-spacing: -0.015em;
		color: var(--color-text-primary);
		margin: 0;
	}

	.archive-deck {
		font-family: var(--font-body);
		font-size: 1.1875rem;
		line-height: 1.55;
		color: var(--color-text-secondary);
		margin: 1.25rem 0 0;
		max-width: 34rem;
	}

	.archive-year {
		margin-top: 3.5rem;
	}

	.archive-year:first-of-type {
		margin-top: 0;
	}

	.archive-year-header {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		padding-bottom: 0.75rem;
		border-bottom: 1px solid var(--color-border);
	}

	.archive-year-label {
		font-family: var(--font-mono);
		font-size: 0.875rem;
		letter-spacing: 0.08em;
		color: var(--color-text-primary);
	}

	.archive-year-count {
		font-family: var(--font-mono);
		font-size: 0.6875rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-text-tertiary);
	}

	.archive-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.archive-item {
		margin: 0;
		border-bottom: 1px solid var(--color-border);
	}

	.archive-link {
		display: block;
		padding: 2rem 0 2.25rem;
		text-decoration: none;
		color: inherit;
	}

	.archive-meta {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		font-family: var(--font-mono);
		font-size: 0.75rem;
		color: var(--color-text-tertiary);
		margin-bottom: 0.75rem;
	}

	.archive-featured {
		color: var(--color-accent);
		text-transform: uppercase;
		letter-spacing: 0.14em;
		font-size: 0.6875rem;
	}

	.archive-title {
		font-family: var(--font-display);
		font-weight: 500;
		font-size: 1.75rem;
		line-height: 1.15;
		letter-spacing: -0.01em;
		color: var(--color-text-primary);
		margin: 0 0 0.6rem;
		transition: color 0.25s var(--ease-standard);
	}

	.archive-item.is-featured .archive-title {
		font-size: clamp(2rem, 3.6vw, 2.5rem);
	}

	.archive-link:hover .archive-title {
		color: var(--color-accent);
	}

	.archive-description {
		font-family: var(--font-body);
		font-size: 1.0625rem;
		line-height: 1.6;
		color: var(--color-text-secondary);
		margin: 0;
		max-width: 40rem;
	}

	.archive-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.25rem 1.25rem;
		margin-top: 1rem;
	}

	.archive-tag {
		font-family: var(--font-mono);
		font-size: 0.6875rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-text-tertiary);
	}

	@media (max-width: 768px) {
		.archive-year {
			margin-top: 2.5rem;
		}

		.archive-title {
			font-size: 1.5rem;
		}

		.archive-description {
			font-size: 1rem;
		}
	}
</style>
