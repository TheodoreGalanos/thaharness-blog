<!-- ABOUTME: Blog archive page displaying all posts as a masonry card grid. -->
<!-- ABOUTME: Uses pretext height prediction for CLS-free layout with CSS grid fallback. -->
---
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import TagPill from '../../components/TagPill.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { getPublishedBlogPosts } from '../../utils/blog';

const posts = getPublishedBlogPosts(await getCollection('blog'));
---

<!doctype html>
<html lang="en" data-theme="dark">
	<head>
		<BaseHead title={`Articles on Harness Engineering & Agentic AI in AEC | ${SITE_TITLE}`} description="Articles on harness engineering, agent evaluation, and building reliable AI systems for architecture, engineering, and construction (AEC) work." />
	</head>
	<body class="bg-[--color-bg]">
		<Header />
		<main class="page-shell py-14 md:py-16">
			<h1 class="font-heading font-medium text-3xl md:text-[3rem] tracking-[-0.02em] text-[--color-text-primary] mb-10">
				Writing
			</h1>

			<section data-masonry-grid>
				{
					posts.map((post) => (
						<article
							class="masonry-card border border-[--color-border] rounded-lg p-5 bg-[--color-surface]"
							data-masonry-card
							data-title={post.data.title}
							data-description={post.data.description}
						>
							<a
								href={`/blog/${post.id}/`}
								class="block no-underline group"
							>
								<div class="mb-3">
									<FormattedDate date={post.data.pubDate} />
								</div>
								<span class="block font-heading font-semibold text-lg text-[--color-text-primary] group-hover:text-[--color-accent] transition-colors duration-250">
									{post.data.title}
								</span>
								<p class="mt-2 mb-0 text-sm text-[--color-text-secondary] line-clamp-3">
									{post.data.description}
								</p>
								{post.data.tags.length > 0 && (
									<div class="mt-3 flex flex-wrap gap-2">
										{post.data.tags.map((tag: string) => (
											<TagPill tag={tag} />
										))}
									</div>
								)}
							</a>
						</article>
					))
				}
			</section>
		</main>
		<Footer />
		<Analytics />
		<SpeedInsights />
		<script src="../../scripts/masonry-index.ts"></script>
		<script src="../../scripts/balanced-headlines.ts"></script>
	</body>
</html>
