<!-- ABOUTME: Blog archive page listing all posts in chronological order. -->
<!-- ABOUTME: Each post displays as a row with date, title, description, and tags. -->
---
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import TagPill from '../../components/TagPill.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { getPublishedBlogPosts } from '../../utils/blog';

const posts = getPublishedBlogPosts(await getCollection('blog'));
---

<!doctype html>
<html lang="en" data-theme="dark">
	<head>
		<BaseHead title={`Articles on Harness Engineering & Agentic AI in AEC | ${SITE_TITLE}`} description="Articles on harness engineering, agent evaluation, and building reliable AI systems for architecture, engineering, and construction (AEC) work." />
	</head>
	<body class="bg-[--color-bg]">
		<Header />
		<main class="page-shell py-14 md:py-16">
			<h1 class="font-heading font-medium text-3xl md:text-[3rem] tracking-[-0.02em] text-[--color-text-primary] mb-10">
				Writing
			</h1>

			<section>
				{
					posts.map((post) => (
						<article class="border-t border-[--color-border] py-5">
							<a
								href={`/blog/${post.id}/`}
								class="block no-underline group transition-colors duration-250 hover:bg-[--color-surface] -mx-3 px-3 rounded"
							>
								<div class="flex-1 min-w-0">
									<div class="mb-3">
										<FormattedDate date={post.data.pubDate} />
									</div>
									<span class="block font-body font-semibold text-[--color-text-primary] group-hover:text-[--color-accent] transition-colors duration-250">
										{post.data.title}
									</span>
									<p class="mt-1 mb-0 text-sm text-[--color-text-secondary]">
										{post.data.description}
									</p>
									{post.data.tags.length > 0 && (
										<div class="mt-3 -ml-2.5 flex w-full flex-wrap content-start items-start gap-x-4 gap-y-3 text-left">
											{post.data.tags.map((tag: string) => (
												<TagPill tag={tag} />
											))}
										</div>
									)}
								</div>
							</a>
						</article>
					))
				}
			</section>
		</main>
		<Footer />
		<Analytics />
		<SpeedInsights />
		<script src="../../scripts/balanced-headlines.ts"></script>
	</body>
</html>
