<!-- ABOUTME: Tag-filtered blog listing page generated for each unique tag. -->
<!-- ABOUTME: Uses getStaticPaths to create a page per tag showing all matching posts. -->
---
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import TagPill from '../../components/TagPill.astro';
import { SITE_TITLE } from '../../consts';
import { getPublishedBlogPosts } from '../../utils/blog';

export async function getStaticPaths() {
	const posts = getPublishedBlogPosts(await getCollection('blog'));
	const tagSet = new Set<string>();
	for (const post of posts) {
		for (const tag of post.data.tags) {
			tagSet.add(tag);
		}
	}

	return Array.from(tagSet).map((tag) => {
		const filtered = posts
			.filter((post) => post.data.tags.includes(tag))
			.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
		return {
			params: { tag },
			props: { posts: filtered },
		};
	});
}

interface Props {
	posts: Awaited<ReturnType<typeof getCollection<'blog'>>>;
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="dark">
	<head>
		<BaseHead title={`${tag} — articles and research | ${SITE_TITLE}`} description={`Articles on ${tag}: harness engineering research, agent evaluation, and practical AI for AEC and domain-specific engineering.`} />
	</head>
	<body class="bg-[--color-bg]">
		<Header />
		<main class="page-shell py-14 md:py-16">
			<h1 class="font-heading font-medium text-3xl md:text-[3rem] tracking-[-0.02em] text-[--color-accent] mb-4 md:mb-6">
				#{tag}
			</h1>
			<p class="max-w-[--width-content] mb-8 md:mb-10 text-base md:text-lg text-[--color-text-secondary]">
				Posts in this topic thread.
			</p>

			<section>
				{
					posts.map((post) => (
						<a
							href={`/blog/${post.id}/`}
							class="flex flex-col gap-1.5 py-5 border-t border-[--color-border] no-underline group transition-colors duration-250 hover:bg-[--color-surface] -mx-3 px-3 rounded md:flex-row md:items-baseline md:gap-6"
						>
							<span class="font-heading text-[0.8125rem] text-[--color-text-tertiary] shrink-0 w-[7rem]">
								{post.data.pubDate.toISOString().split('T')[0]}
							</span>
							<div class="flex-1 min-w-0">
								<span class="font-body font-semibold text-[--color-text-primary] group-hover:text-[--color-accent] transition-colors duration-250">
									{post.data.title}
								</span>
								<p class="mt-1 mb-0 text-sm text-[--color-text-secondary] line-clamp-1">
									{post.data.description}
								</p>
							</div>
							{post.data.tags.length > 0 && (
								<span class="mt-0.5 flex w-full flex-wrap gap-x-4 gap-y-3 text-left md:mt-0 md:w-auto md:shrink-0 md:justify-end">
									{post.data.tags.map((t: string) => (
										<TagPill tag={t} />
									))}
								</span>
							)}
						</a>
					))
				}
			</section>
		</main>
		<Footer />
		<Analytics />
		<SpeedInsights />
	</body>
</html>
