<!-- ABOUTME: Search page powered by Pagefind for full-text static search. -->
<!-- ABOUTME: Editorial treatment — Fraunces headline, mono kicker, Pagefind result styling tuned to editorial link language. -->
---
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en" data-theme="dark">
	<head>
		<BaseHead title={`Search | ${SITE_TITLE}`} description="Search all posts and pages." noindex={true} />
		<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
		<style>
			.search-kicker {
				display: inline-block;
				font-family: var(--font-mono);
				font-size: 0.6875rem;
				text-transform: uppercase;
				letter-spacing: 0.14em;
				color: var(--color-accent);
				margin-bottom: 1.25rem;
			}

			.search-headline {
				font-family: var(--font-display);
				font-weight: 500;
				font-size: clamp(2.25rem, 5vw, 3.5rem);
				line-height: 1.1;
				letter-spacing: -0.015em;
				color: var(--color-text-primary);
				margin: 0;
			}

			.search-deck {
				font-family: var(--font-body);
				font-size: 1.1875rem;
				line-height: 1.55;
				color: var(--color-text-secondary);
				max-width: 36rem;
				margin: 1.25rem 0 2.5rem;
			}

			.pagefind-ui .pagefind-ui__search-input {
				font-family: var(--font-mono);
				font-size: 16px;
				border-color: var(--color-border);
				color: var(--color-text-primary);
				background: var(--color-surface);
				padding: 0.95rem 1rem;
				border-radius: 8px;
				min-height: 3rem;
			}
			.pagefind-ui .pagefind-ui__search-input:focus {
				border-color: var(--color-accent);
				outline: none;
				box-shadow: 0 0 0 2px rgba(232, 168, 76, 0.2);
			}
			[data-theme="light"] .pagefind-ui .pagefind-ui__search-input:focus {
				box-shadow: 0 0 0 2px rgba(212, 136, 44, 0.2);
			}
			.pagefind-ui .pagefind-ui__result-link {
				font-family: var(--font-display);
				font-weight: 500;
				font-size: 1.375rem;
				line-height: 1.2;
				letter-spacing: -0.01em;
				color: var(--color-text-primary);
				text-decoration: none;
				background-image: linear-gradient(var(--color-text-tertiary), var(--color-text-tertiary));
				background-size: 100% 1px;
				background-position: 0 100%;
				background-repeat: no-repeat;
				transition: color 0.25s var(--ease-standard), background-image 0.25s var(--ease-standard);
			}
			.pagefind-ui .pagefind-ui__result-link:hover {
				color: var(--color-accent);
				background-image: linear-gradient(var(--color-accent), var(--color-accent));
			}
			.pagefind-ui .pagefind-ui__result-excerpt {
				font-family: var(--font-body);
				font-size: 1rem;
				line-height: 1.6;
				color: var(--color-text-secondary);
			}
			.pagefind-ui .pagefind-ui__results-area {
				margin-top: 2.5rem;
			}
			.pagefind-ui .pagefind-ui__result {
				padding: 1.75rem 0;
				border-top: 1px solid var(--color-border);
			}
			.pagefind-ui .pagefind-ui__button,
			.pagefind-ui .pagefind-ui__search-clear,
			.pagefind-ui .pagefind-ui__search-clear-icon {
				min-height: 2.75rem;
			}
			.pagefind-ui .pagefind-ui__message,
			.pagefind-ui .pagefind-ui__button {
				font-family: var(--font-mono);
				font-size: 0.8125rem;
				color: var(--color-text-secondary);
			}
			@media (max-width: 768px) {
				.pagefind-ui .pagefind-ui__search-input {
					padding: 1rem;
					font-size: 16px;
				}

				.pagefind-ui .pagefind-ui__result-link {
					font-size: 1.1875rem;
				}

				.pagefind-ui .pagefind-ui__result {
					padding: 1.4rem 0;
				}
			}
		</style>
	</head>
	<body class="bg-[--color-bg]">
		<Header />
		<main class="px-6 py-16 md:py-24">
			<section class="mx-auto max-w-[42rem]">
				<span class="search-kicker">Search</span>
				<h1 class="search-headline">Find a piece</h1>
				<p class="search-deck">
					Full-text search across the published writing on The Harness. Results update as you type.
				</p>
				<div id="search"></div>
			</section>
		</main>
		<Footer />
		<script is:inline src="/pagefind/pagefind-ui.js"></script>
		<script is:inline>
			window.addEventListener('DOMContentLoaded', function() {
				new PagefindUI({
					element: '#search',
					showSubResults: true,
					showImages: false,
				});
				var params = new URLSearchParams(window.location.search);
				var query = params.get('q');
				if (!query) return;
				window.setTimeout(function() {
					var input = document.querySelector('.pagefind-ui__search-input');
					if (!(input instanceof HTMLInputElement)) return;
					input.value = query;
					input.dispatchEvent(new Event('input', { bubbles: true }));
				}, 50);
			});
		</script>
		<Analytics />
		<SpeedInsights />
	</body>
</html>
