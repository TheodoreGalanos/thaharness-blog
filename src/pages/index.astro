<!-- ABOUTME: Landing page introducing The Harness. -->
<!-- ABOUTME: Editorial tagline + manifesto + latest post, dressed in landing-page terminal chrome (blueprint grid, sheet corners, status bar, command buttons). -->
---
import { Image } from 'astro:assets';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import { getCollection } from 'astro:content';
import logoIcon from '../assets/logo-icon-trimmed.png';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import BlueprintBg from '../components/landing/BlueprintBg.astro';
import HeroReadout from '../components/landing/HeroReadout.astro';
import SectionAnno from '../components/landing/SectionAnno.astro';
import SheetCorners from '../components/landing/SheetCorners.astro';
import StatusBar from '../components/landing/StatusBar.astro';
import { SITE_DESCRIPTION, SITE_TAGLINE, SITE_TITLE } from '../consts';
import { getPublishedBlogPosts } from '../utils/blog';

const posts = getPublishedBlogPosts(await getCollection('blog'));
const latestPost = posts[0];

const TOPICS = [
	{
		title: 'Harness Engineering',
		description: 'The tools, verifiers, orchestration, and process design that make agentic work reliable. Not the model — the system around it.',
		tag: 'harness-engineering',
		count: posts.filter(p => p.data.tags.includes('harness-engineering')).length,
	},
	{
		title: 'Agent Evaluation',
		description: 'Benchmarking agents on real engineering tasks. What to measure, how to measure it, and why most evals miss what matters.',
		tag: 'agent-evaluation',
		count: posts.filter(p => p.data.tags.includes('agent-evaluation') || p.data.tags.includes('ai-benchmarks')).length,
	},
	{
		title: 'AI in AEC',
		description: 'Applying agentic AI to architecture, engineering, and construction — where the work is instance-bound, constraint-heavy, and intolerant of generic answers.',
		tag: 'ai-in-aec',
		count: posts.filter(p => p.data.tags.includes('ai-in-aec')).length,
	},
];

// Real numbers for the status bar — no fake counters.
const allTags = new Set(posts.flatMap(p => p.data.tags ?? []));
const totalPosts = posts.length;
const totalTopics = allTags.size;
const lastPostDate = latestPost?.data.pubDate ?? new Date();

// Recent posts row list — everything after the latest, capped to keep the page tight.
const recentPosts = posts.slice(1, 6);

// Pick the rarest tag per post for the chip — avoids a column of repeated "harness-engineering".
// Frontmatter is untouched (SEO/tag pages still use the full list).
const tagFreq = new Map<string, number>();
for (const post of posts) {
	for (const tag of post.data.tags ?? []) {
		tagFreq.set(tag, (tagFreq.get(tag) ?? 0) + 1);
	}
}
function distinctiveTag(tags: string[] | undefined): string | undefined {
	if (!tags || tags.length === 0) return undefined;
	return tags
		.map((tag, index) => ({ tag, index, freq: tagFreq.get(tag) ?? 0 }))
		.sort((a, b) => a.freq - b.freq || a.index - b.index)[0]?.tag;
}
---

<!doctype html>
<html lang="en" data-theme="dark">
	<head>
		<BaseHead title={`${SITE_TITLE} — Harness Engineering & Agentic AI for AEC`} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-[--color-bg]">
		<Header />
		<StatusBar posts={totalPosts} topics={totalTopics} lastPostDate={lastPostDate} />
		<main>
			<!-- SECTION 01 / OPENING — single-viewport masthead -->
			<BlueprintBg class="home-section home-hero scanlines">
				<SheetCorners figNumber={1} figName="OPENING" totalSheets={4} />
				<HeroReadout postCount={totalPosts} />
				<div class="home-section-inner home-hero-inner">
					<div class="mx-auto w-full max-w-[--width-wide]">
						<SectionAnno number={1} name="Opening" />
					</div>
					<div class="home-hero-stack">
						<Image
							src={logoIcon}
							alt="The Harness logo"
							width={56}
							height={82}
							class="logo-hero"
						/>
						<h1 class="home-tagline">
							{SITE_TAGLINE}<span aria-hidden="true" class="headline-cursor"></span>
						</h1>
						<p class="home-subtagline">
							Where reliable AI agent capability actually comes from — and how to build it.
						</p>
						<div class="home-manifesto-block">
							<p class="home-manifesto">
								In engineering, AI capability does not live in the model alone. It is distributed across tools, verifiers, control flow, and the design of the operating environment. <strong class="home-manifesto-strong">The Harness</strong> is a working notebook on that problem — writing from the intersection of agentic AI and architecture, engineering, and construction.
							</p>
							<p class="home-manifesto-byline">
								Written by <a href="/about">Theodoros Galanos</a>.
							</p>
						</div>
					</div>
					<div class="home-hero-cta">
						<a href="/blog/" class="cmd-btn cmd-btn-primary">
							<span aria-hidden="true" class="cmd-btn-sigil">$</span>read_archive
						</a>
						<a href="/subscribe" class="cmd-btn">
							<span aria-hidden="true" class="cmd-btn-sigil cmd-btn-sigil-teal">&gt;</span>subscribe
						</a>
					</div>
				</div>
			</BlueprintBg>

			<!-- SECTION 02 / TOPICS — newspaper-style 3-column grid -->
			<section class="home-section home-section-wide">
				<div class="home-section-inner">
					<div class="mx-auto max-w-[--width-wide]">
						<SectionAnno number={2} name="Topics" />
						<div class="topic-grid">
							{TOPICS.map((topic, index) => (
								<a href={`/tags/${topic.tag}/`} class="topic-card">
									<span class="topic-card-num">{String(index + 1).padStart(2, '0')}</span>
									<h3 class="topic-card-title">{topic.title}</h3>
									<p class="topic-card-description">{topic.description}</p>
									<span class="topic-card-count">
										{topic.count} {topic.count === 1 ? 'article' : 'articles'} <span aria-hidden="true">→</span>
									</span>
								</a>
							))}
						</div>
					</div>
				</div>
			</section>

			<!-- SECTION 03 / LATEST — feature treatment -->
			{latestPost && (
				<section class="home-section home-section-wide">
					<div class="home-section-inner">
						<div class="mx-auto max-w-[--width-wide]">
							<SectionAnno number={3} name="Latest" />
							<a href={`/blog/${latestPost.id}/`} class="feature-card">
								<div class="feature-meta">
									<FormattedDate date={latestPost.data.pubDate} />
									{distinctiveTag(latestPost.data.tags) && (
										<span class="feature-meta-tag">{distinctiveTag(latestPost.data.tags)}</span>
									)}
									<span class="feature-meta-continue" aria-hidden="true">
										<span class="cmd-btn-sigil cmd-btn-sigil-teal">&gt;</span>continue_reading
									</span>
								</div>
								<div class="feature-body">
									<h2 class="feature-title">{latestPost.data.title}</h2>
									<p class="feature-deck">{latestPost.data.description}</p>
								</div>
							</a>
						</div>
					</div>
				</section>
			)}

			<!-- SECTION 04 / RECENT — table-row list of remaining posts -->
			{recentPosts.length > 0 && (
				<section class="home-section home-section-wide">
					<div class="home-section-inner">
						<div class="mx-auto max-w-[--width-wide]">
							<SectionAnno number={4} name="Recent" />
							<ul class="recent-list" role="list">
								{recentPosts.map((post) => (
									<li class="recent-row">
										<a href={`/blog/${post.id}/`} class="recent-row-link">
											<span class="recent-row-date">
												<FormattedDate date={post.data.pubDate} />
											</span>
											{distinctiveTag(post.data.tags) && (
												<span class="recent-row-tag">{distinctiveTag(post.data.tags)}</span>
											)}
											<span class="recent-row-body">
												<span class="recent-row-title">{post.data.title}</span>
												<span class="recent-row-deck">{post.data.description}</span>
											</span>
										</a>
									</li>
								))}
							</ul>
						</div>
					</div>
				</section>
			)}

		</main>
		<Footer />
		<Analytics />
		<SpeedInsights />
	</body>
</html>

<style>
	.home-section {
		padding-left: 1.5rem;
		padding-right: 1.5rem;
		padding-top: 4rem;
		padding-bottom: 4rem;
	}

	@media (min-width: 768px) {
		.home-section {
			padding-top: 5rem;
			padding-bottom: 5rem;
		}
	}

	.home-section-inner {
		position: relative;
	}

	/* Single-viewport masthead — fills the screen below the header + status bar.
	   Header is 4rem (mobile) / 4.25rem (md+); status bar adds ~2.4rem. */
	.home-hero {
		padding-top: 0;
		padding-bottom: 0;
		min-height: calc(100svh - 6.4rem);
		display: flex;
	}

	@media (min-width: 768px) {
		.home-hero {
			min-height: calc(100svh - 6.65rem);
		}
	}

	.home-hero-inner {
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		gap: 2.5rem;
		width: 100%;
		padding: 2.5rem 1.5rem 3rem;
	}

	@media (min-width: 768px) {
		.home-hero-inner {
			padding: 3rem 1.5rem 3.5rem;
			gap: 3rem;
		}
	}

	/* Centred stack — single column, vertically centred inside the masthead.
	   Holds logo → tagline → subtagline → manifesto block, all aligned centre. */
	.home-hero-stack {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 1.25rem;
		max-width: 52rem;
		margin: 0 auto;
		flex: 1;
		justify-content: center;
		padding: 1rem 0;
	}

	@media (min-width: 768px) {
		.home-hero-stack {
			gap: 1.5rem;
		}
	}

	.logo-hero {
		filter: drop-shadow(0 0 10px rgba(232, 168, 76, 0.35));
		margin: 0 auto;
	}

	.home-tagline {
		font-family: var(--font-display);
		font-style: italic;
		font-weight: 400;
		font-size: clamp(2rem, 4.8vw, 3.25rem);
		line-height: 1.1;
		letter-spacing: -0.015em;
		color: var(--color-text-primary);
		margin: 0;
		text-align: center;
	}

	.home-subtagline {
		font-family: var(--font-body);
		font-size: 1.0625rem;
		line-height: 1.55;
		color: var(--color-text-secondary);
		max-width: 36rem;
		margin: 0 auto;
		text-align: center;
	}

	@media (min-width: 768px) {
		.home-subtagline {
			font-size: 1.1875rem;
		}
	}

	/* Manifesto block — sits below subtagline as a generous serif paragraph,
	   visually anchored by a hairline above. */
	.home-manifesto-block {
		max-width: 44rem;
		margin: 1rem auto 0;
		padding-top: 1.75rem;
		border-top: 1px solid var(--color-border);
		display: flex;
		flex-direction: column;
		gap: 0.85rem;
	}

	.home-manifesto {
		font-family: var(--font-body);
		font-size: 1rem;
		line-height: 1.6;
		color: var(--color-text-secondary);
		margin: 0;
		text-align: center;
	}

	@media (min-width: 768px) {
		.home-manifesto {
			font-size: 1.0625rem;
		}
	}

	.home-manifesto-strong {
		color: var(--color-text-primary);
		font-weight: 600;
	}

	.home-manifesto-byline {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		letter-spacing: 0.04em;
		color: var(--color-text-tertiary);
		margin: 0;
		text-align: center;
	}

	.home-manifesto-byline a {
		color: var(--color-text-secondary);
		text-decoration: none;
		background-image: linear-gradient(
			var(--color-text-tertiary),
			var(--color-text-tertiary)
		);
		background-size: 100% 1px;
		background-position: 0 100%;
		background-repeat: no-repeat;
		transition:
			color 0.25s var(--ease-standard),
			background-image 0.25s var(--ease-standard);
	}

	.home-manifesto-byline a:hover {
		color: var(--color-accent);
		background-image: linear-gradient(var(--color-accent), var(--color-accent));
	}

	.home-hero-cta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		align-items: center;
		justify-content: center;
	}

	/* Wide sections — newspaper layout uses full --width-wide, not the 42rem reading column */
	.home-section-wide {
		padding-top: 3rem;
		padding-bottom: 3rem;
	}

	@media (min-width: 768px) {
		.home-section-wide {
			padding-top: 3.5rem;
			padding-bottom: 3.5rem;
		}
	}

	/* SECTION anno spacing on wide sections — drop in below the heading band */
	.home-section-wide .anno {
		display: inline-flex;
		margin-bottom: 1.75rem;
	}

	/* ────────────────────────────────────────────────────────
	   SECTION 02 / TOPICS — three-column equal grid
	   ──────────────────────────────────────────────────────── */
	.topic-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2rem 2.5rem;
		border-top: 1px solid var(--color-border);
		padding-top: 1.75rem;
	}

	@media (min-width: 768px) {
		.topic-grid {
			grid-template-columns: repeat(3, 1fr);
			gap: 0 2.5rem;
		}
	}

	.topic-card {
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
		text-decoration: none;
		color: inherit;
		padding-bottom: 0.5rem;
		transition: color 0.25s var(--ease-standard);
	}

	@media (min-width: 768px) {
		.topic-card + .topic-card {
			border-left: 1px solid var(--color-border);
			padding-left: 2rem;
			margin-left: -0.5rem;
		}
	}

	.topic-card-num {
		font-family: var(--font-mono);
		font-size: 0.6875rem;
		letter-spacing: 0.14em;
		color: var(--color-text-tertiary);
		text-transform: uppercase;
		transition: color 0.25s var(--ease-standard);
	}

	.topic-card:hover .topic-card-num {
		color: var(--color-accent);
	}

	.topic-card-title {
		font-family: var(--font-display);
		font-weight: 500;
		font-size: 1.5rem;
		line-height: 1.2;
		letter-spacing: -0.01em;
		color: var(--color-text-primary);
		margin: 0;
		transition: color 0.25s var(--ease-standard);
	}

	.topic-card:hover .topic-card-title {
		color: var(--color-accent);
	}

	.topic-card-description {
		font-family: var(--font-body);
		font-size: 0.9375rem;
		line-height: 1.55;
		color: var(--color-text-secondary);
		margin: 0;
	}

	.topic-card-count {
		font-family: var(--font-mono);
		font-size: 0.6875rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-text-tertiary);
		margin-top: 0.4rem;
		transition: color 0.25s var(--ease-standard);
	}

	.topic-card:hover .topic-card-count {
		color: var(--color-text-secondary);
	}

	/* ────────────────────────────────────────────────────────
	   SECTION 03 / LATEST — feature card, meta-left + body-right
	   ──────────────────────────────────────────────────────── */
	.feature-card {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5rem;
		border-top: 1px solid var(--color-border);
		padding-top: 1.75rem;
		text-decoration: none;
		color: inherit;
	}

	@media (min-width: 768px) {
		.feature-card {
			grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
			gap: 3rem;
		}
	}

	.feature-meta {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		font-family: var(--font-mono);
		font-size: 0.75rem;
		letter-spacing: 0.04em;
		color: var(--color-text-tertiary);
	}

	.feature-meta :global(time) {
		color: var(--color-text-secondary);
	}

	.feature-meta-tag {
		text-transform: uppercase;
		letter-spacing: 0.12em;
		font-size: 0.6875rem;
		color: var(--color-accent-secondary);
	}

	.feature-meta-continue {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		margin-top: 0.5rem;
		color: var(--color-text-secondary);
		transition: color 0.25s var(--ease-standard);
	}

	.feature-card:hover .feature-meta-continue {
		color: var(--color-accent);
	}

	.feature-body {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.feature-title {
		font-family: var(--font-display);
		font-weight: 500;
		font-size: clamp(1.875rem, 4vw, 2.75rem);
		line-height: 1.12;
		letter-spacing: -0.015em;
		color: var(--color-text-primary);
		margin: 0;
		transition: color 0.25s var(--ease-standard);
	}

	.feature-card:hover .feature-title {
		color: var(--color-accent);
	}

	.feature-deck {
		font-family: var(--font-body);
		font-size: 1.0625rem;
		line-height: 1.55;
		color: var(--color-text-secondary);
		margin: 0;
	}

	@media (min-width: 768px) {
		.feature-deck {
			font-size: 1.125rem;
		}
	}

	/* ────────────────────────────────────────────────────────
	   SECTION 04 / RECENT — compact row list (date · tag · title · deck)
	   ──────────────────────────────────────────────────────── */
	.recent-list {
		list-style: none;
		margin: 0;
		padding: 0;
		border-top: 1px solid var(--color-border);
	}

	.recent-row {
		margin: 0;
		border-bottom: 1px solid var(--color-border);
	}

	.recent-row-link {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.4rem;
		padding: 1.25rem 0;
		text-decoration: none;
		color: inherit;
		transition: color 0.25s var(--ease-standard);
	}

	@media (min-width: 768px) {
		.recent-row-link {
			grid-template-columns: 7rem 13rem 1fr;
			align-items: baseline;
			gap: 1.5rem;
			padding: 1.1rem 0;
		}
	}

	.recent-row-tag {
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.recent-row-date {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		color: var(--color-text-tertiary);
	}

	.recent-row-date :global(time) {
		color: var(--color-text-tertiary);
	}

	.recent-row-tag {
		font-family: var(--font-mono);
		font-size: 0.6875rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-accent-secondary);
	}

	.recent-row-body {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		min-width: 0;
	}

	.recent-row-title {
		font-family: var(--font-display);
		font-weight: 500;
		font-size: 1.125rem;
		line-height: 1.3;
		letter-spacing: -0.01em;
		color: var(--color-text-primary);
		transition: color 0.25s var(--ease-standard);
	}

	.recent-row-link:hover .recent-row-title {
		color: var(--color-accent);
	}

	.recent-row-deck {
		font-family: var(--font-body);
		font-size: 0.9375rem;
		line-height: 1.5;
		color: var(--color-text-secondary);
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
</style>
