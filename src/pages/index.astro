<!-- ABOUTME: Landing page introducing The Harness, its mission, and key topic areas. -->
<!-- ABOUTME: Features hero, manifesto, latest article, topic pillars, and scroll to footer newsletter. -->
---
import { Image } from 'astro:assets';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import { getCollection } from 'astro:content';
import logoIcon from '../assets/logo-icon-trimmed.png';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TAGLINE, SITE_TITLE } from '../consts';
import { getPublishedBlogPosts } from '../utils/blog';

const posts = getPublishedBlogPosts(await getCollection('blog'));
const latestPost = posts[0];

const PILLARS = [
	{
		title: 'Harness Engineering',
		description: 'The tools, verifiers, orchestration, and process design that make agentic work reliable. Not the model — the system around it.',
		tag: 'harness-engineering',
		count: posts.filter(p => p.data.tags.includes('harness-engineering')).length,
	},
	{
		title: 'Agent Evaluation',
		description: 'Benchmarking agents on real engineering tasks. What to measure, how to measure it, and why most evals miss what matters.',
		tag: 'agent-evaluation',
		count: posts.filter(p => p.data.tags.includes('agent-evaluation') || p.data.tags.includes('ai-benchmarks')).length,
	},
	{
		title: 'AI in AEC',
		description: 'Applying agentic AI to architecture, engineering, and construction — where the work is instance-bound, constraint-heavy, and intolerant of generic answers.',
		tag: 'ai-in-aec',
		count: posts.filter(p => p.data.tags.includes('ai-in-aec')).length,
	},
];
---

<!doctype html>
<html lang="en" data-theme="dark">
	<head>
		<BaseHead title={`${SITE_TITLE} — Harness Engineering & Agentic AI for AEC`} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-[--color-bg]">
		<Header />
		<main>
			<!-- Hero -->
			<section class="px-6 pt-12 pb-6 md:pt-20 md:pb-10 relative">
				<div class="mx-auto max-w-[--width-wide] text-center">
					<Image
						src={logoIcon}
						alt="The Harness logo"
						width={56}
						height={82}
						class="mx-auto mb-5 logo-hero"
					/>
					<h1 class="font-body italic text-3xl md:text-5xl text-[--color-text-primary] leading-tight">
						{SITE_TAGLINE}
					</h1>
					<p class="mt-3 text-[--color-text-secondary] text-base md:text-lg max-w-2xl mx-auto">
						Where reliable AI agent capability actually comes from — and how to build it.
					</p>
				</div>
				<!-- Scroll indicator -->
				<div class="mt-8 flex justify-center scroll-hint" aria-hidden="true">
					<svg width="20" height="28" viewBox="0 0 20 28" fill="none" stroke="var(--color-text-tertiary)" stroke-width="1.5" stroke-linecap="round">
						<path d="M10 4 L10 20" />
						<path d="M4 16 L10 22 L16 16" />
					</svg>
				</div>
			</section>

			<!-- Manifesto -->
			<section class="px-6 pb-10 md:pb-12">
				<div class="mx-auto max-w-2xl">
					<div class="border-t border-[--color-border] pt-8">
						<p class="text-[--color-text-secondary] text-base md:text-lg leading-relaxed">
							In engineering, AI capability does not live in the model alone. It is distributed across tools, verifiers, control flow, and the design of the operating environment. <strong class="text-[--color-text-primary]">The Harness</strong> is a working notebook on that problem — writing from the intersection of agentic AI and architecture, engineering, and construction.
						</p>
						<p class="mt-3 text-[--color-text-secondary] text-sm">
							Written by <a href="/about" class="text-[--color-accent] hover:text-[--color-accent-hover]">Theodoros Galanos</a>.
						</p>
					</div>
				</div>
			</section>

			<!-- Latest article -->
			{latestPost && (
				<section class="px-6 pb-10 md:pb-12">
					<div class="mx-auto max-w-[--width-wide]">
						<div class="border-t border-[--color-border] pt-6">
							<span class="font-heading text-[0.6875rem] uppercase tracking-[0.05em] text-[--color-text-tertiary]">
								latest
							</span>
							<a href={`/blog/${latestPost.id}/`} class="block mt-3 no-underline group max-w-3xl">
								<h2 class="font-body font-semibold text-xl md:text-2xl text-[--color-text-primary] group-hover:text-[--color-accent] transition-colors duration-250">
									{latestPost.data.title}
								</h2>
								<p class="mt-1.5 text-[--color-text-secondary] text-sm md:text-base line-clamp-2">
									{latestPost.data.description}
								</p>
								<div class="mt-2 flex items-center gap-3">
									<FormattedDate date={latestPost.data.pubDate} />
								</div>
							</a>
						</div>
					</div>
				</section>
			)}

			<!-- Topic pillars -->
			<section class="px-6 pb-10 md:pb-12">
				<div class="mx-auto max-w-[--width-wide]">
					<div class="border-t border-[--color-border] pt-6">
						<span class="font-heading text-[0.6875rem] uppercase tracking-[0.05em] text-[--color-text-tertiary]">
							Topics
						</span>
						<div class="mt-4 grid gap-4 md:grid-cols-3">
							{PILLARS.map((pillar) => (
								<a
									href={`/tags/${pillar.tag}/`}
									class="block rounded-lg border border-[--color-border] bg-[--color-surface] p-4 no-underline group transition-colors duration-250 hover:border-[--color-accent]"
								>
									<h3 class="font-heading font-medium text-sm text-[--color-text-primary] group-hover:text-[--color-accent] transition-colors duration-250">
										{pillar.title}
									</h3>
									<p class="mt-1.5 text-xs text-[--color-text-secondary] leading-relaxed">
										{pillar.description}
									</p>
									<span class="mt-2 inline-block font-heading text-[0.625rem] uppercase tracking-[0.05em] text-[--color-text-tertiary]">
										{pillar.count} {pillar.count === 1 ? 'article' : 'articles'}
									</span>
								</a>
							))}
						</div>
					</div>
				</div>
			</section>

			<!-- All articles link -->
			<section class="px-6 pb-10">
				<div class="mx-auto max-w-[--width-wide] text-center">
					<a
						href="/blog/"
						class="inline-block font-heading text-sm text-[--color-accent] hover:text-[--color-accent-hover] transition-colors duration-250"
					>
						Read all articles &rarr;
					</a>
				</div>
			</section>
		</main>
		<Footer />
		<Analytics />
		<SpeedInsights />
		<script src="../scripts/balanced-headlines.ts"></script>
	</body>
</html>

<style>
	.logo-hero {
		filter: drop-shadow(0 0 10px rgba(232, 168, 76, 0.35));
	}

	.scroll-hint {
		animation: bob 2s ease-in-out infinite;
		opacity: 0.5;
	}

	@keyframes bob {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(6px); }
	}
</style>
