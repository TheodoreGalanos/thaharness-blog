<!-- ABOUTME: Home page with terminal-style hero, featured latest post, and chronological post list. -->
<!-- ABOUTME: Pulls blog posts sorted by date and renders The Harness dark-mode-first landing. -->
---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TagPill from '../components/TagPill.astro';
import { SITE_DESCRIPTION, SITE_SUBTITLE, SITE_TAGLINE, SITE_TITLE } from '../consts';
import { getPublishedBlogPosts } from '../utils/blog';

const posts = getPublishedBlogPosts(await getCollection('blog'));

const latestPost = posts[0];
const remainingPosts = posts.slice(1);
---

<!doctype html>
<html lang="en" data-theme="dark">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-[--color-bg]">
		<Header />
		<main>
			<!-- Hero section -->
			<section class="px-6 py-16 md:py-24 lg:py-28">
				<div class="mx-auto max-w-[--width-wide] text-center">
					<p class="font-body italic text-3xl md:text-5xl text-[--color-text-primary] leading-tight">
						{SITE_TAGLINE}
					</p>
					<p class="mt-4 text-[--color-text-tertiary] text-lg md:text-xl">
						{SITE_SUBTITLE}
					</p>
				</div>
			</section>

			<!-- Featured latest post -->
			{latestPost && (
				<section class="px-6">
					<div class="mx-auto max-w-[--width-wide] border-t border-[--color-border] pt-8 pb-10">
						<span class="font-heading text-[0.6875rem] uppercase tracking-[0.05em] text-[--color-text-tertiary]">
							latest
						</span>
						<a href={`/blog/${latestPost.id}/`} class="block mt-4 no-underline group max-w-3xl">
							<h2 class="font-body font-semibold text-[1.75rem] md:text-[2rem] text-[--color-text-primary] group-hover:text-[--color-accent] transition-colors duration-250">
								{latestPost.data.title}
							</h2>
							<p class="mt-2 text-[--color-text-secondary] text-base">
								{latestPost.data.description}
							</p>
							<div class="mt-3 flex flex-wrap items-center gap-3">
								<FormattedDate date={latestPost.data.pubDate} />
								{latestPost.data.tags.length > 0 && (
									<div class="flex flex-wrap gap-2">
										{latestPost.data.tags.map((tag: string) => (
											<TagPill tag={tag} />
										))}
									</div>
								)}
							</div>
						</a>
					</div>
				</section>
			)}

			<!-- Remaining posts list -->
			{remainingPosts.length > 0 && (
				<section class="px-6 pb-16">
					<div class="mx-auto max-w-[--width-wide]">
						{remainingPosts.map((post) => (
							<a
								href={`/blog/${post.id}/`}
								class="flex flex-col md:flex-row md:items-baseline gap-1 md:gap-6 py-4 border-t border-[--color-border] no-underline group transition-colors duration-250 hover:bg-[--color-surface] -mx-3 px-3 rounded"
							>
								<span class="font-heading text-[0.8125rem] text-[--color-text-tertiary] shrink-0 w-[7rem]">
									{post.data.pubDate.toISOString().split('T')[0]}
								</span>
								<span class="font-body font-semibold text-[--color-text-primary] group-hover:text-[--color-accent] transition-colors duration-250 flex-1">
									{post.data.title}
								</span>
								{post.data.tags.length > 0 && (
									<span class="flex flex-wrap gap-2 shrink-0">
										{post.data.tags.map((tag: string) => (
											<span class="font-heading text-[0.6875rem] uppercase tracking-[0.05em] text-[--color-text-tertiary]">
												{tag}
											</span>
										))}
									</span>
								)}
							</a>
						))}
					</div>
				</section>
			)}
		</main>
		<Footer />
	</body>
</html>
