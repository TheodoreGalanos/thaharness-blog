<!-- ABOUTME: Landing page introducing The Harness, its mission, and topic areas. -->
<!-- ABOUTME: Editorial treatment — Fraunces display tagline, essayistic manifesto, promoted latest article, typeset topic list. -->
---
import { Image } from 'astro:assets';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import { getCollection } from 'astro:content';
import logoIcon from '../assets/logo-icon-trimmed.png';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TAGLINE, SITE_TITLE } from '../consts';
import { getPublishedBlogPosts } from '../utils/blog';

const posts = getPublishedBlogPosts(await getCollection('blog'));
const latestPost = posts[0];

const TOPICS = [
	{
		title: 'Harness Engineering',
		description: 'The tools, verifiers, orchestration, and process design that make agentic work reliable. Not the model — the system around it.',
		tag: 'harness-engineering',
		count: posts.filter(p => p.data.tags.includes('harness-engineering')).length,
	},
	{
		title: 'Agent Evaluation',
		description: 'Benchmarking agents on real engineering tasks. What to measure, how to measure it, and why most evals miss what matters.',
		tag: 'agent-evaluation',
		count: posts.filter(p => p.data.tags.includes('agent-evaluation') || p.data.tags.includes('ai-benchmarks')).length,
	},
	{
		title: 'AI in AEC',
		description: 'Applying agentic AI to architecture, engineering, and construction — where the work is instance-bound, constraint-heavy, and intolerant of generic answers.',
		tag: 'ai-in-aec',
		count: posts.filter(p => p.data.tags.includes('ai-in-aec')).length,
	},
];
---

<!doctype html>
<html lang="en" data-theme="dark">
	<head>
		<BaseHead title={`${SITE_TITLE} — Harness Engineering & Agentic AI for AEC`} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-[--color-bg]">
		<Header />
		<main>
			<!-- Hero -->
			<section class="home-hero px-6 pt-16 pb-14 md:pt-24 md:pb-20">
				<div class="mx-auto max-w-[--width-wide] text-center">
					<Image
						src={logoIcon}
						alt="The Harness logo"
						width={56}
						height={82}
						class="mx-auto mb-8 logo-hero"
					/>
					<h1 class="home-tagline">
						{SITE_TAGLINE}
					</h1>
					<p class="home-subtagline">
						Where reliable AI agent capability actually comes from — and how to build it.
					</p>
				</div>
			</section>

			<!-- Manifesto -->
			<section class="px-6 pb-16 md:pb-20">
				<div class="mx-auto max-w-[42rem]">
					<div class="border-t border-[--color-border] pt-10">
						<p class="home-manifesto">
							In engineering, AI capability does not live in the model alone. It is distributed across tools, verifiers, control flow, and the design of the operating environment. <strong class="text-[--color-text-primary] font-semibold">The Harness</strong> is a working notebook on that problem — writing from the intersection of agentic AI and architecture, engineering, and construction.
						</p>
						<p class="home-manifesto-byline">
							Written by <a href="/about">Theodoros Galanos</a>.
						</p>
					</div>
				</div>
			</section>

			<!-- Latest article -->
			{latestPost && (
				<section class="px-6 pb-16 md:pb-20">
					<div class="mx-auto max-w-[42rem]">
						<div class="border-t border-[--color-border] pt-10">
							<span class="home-kicker">Latest</span>
							<a href={`/blog/${latestPost.id}/`} class="home-latest-link">
								<h2 class="home-latest-title">
									{latestPost.data.title}
								</h2>
								<p class="home-latest-deck">
									{latestPost.data.description}
								</p>
								<div class="home-latest-meta">
									<FormattedDate date={latestPost.data.pubDate} />
								</div>
							</a>
						</div>
					</div>
				</section>
			)}

			<!-- Topics — typeset list instead of cards -->
			<section class="px-6 pb-16 md:pb-20">
				<div class="mx-auto max-w-[42rem]">
					<div class="border-t border-[--color-border] pt-10">
						<span class="home-kicker">Topics</span>
						<ol class="home-topics" role="list">
							{TOPICS.map((topic, index) => (
								<li class="home-topic">
									<a href={`/tags/${topic.tag}/`} class="home-topic-link">
										<span class="home-topic-num">{String(index + 1).padStart(2, '0')}</span>
										<span class="home-topic-body">
											<span class="home-topic-title">{topic.title}</span>
											<span class="home-topic-description">{topic.description}</span>
											<span class="home-topic-count">
												{topic.count} {topic.count === 1 ? 'article' : 'articles'}
											</span>
										</span>
									</a>
								</li>
							))}
						</ol>
					</div>
				</div>
			</section>

			<!-- All articles link -->
			<section class="px-6 pb-12">
				<div class="mx-auto max-w-[42rem]">
					<div class="border-t border-[--color-border] pt-8 text-center">
						<a href="/blog/" class="home-all-link">
							Read all articles &rarr;
						</a>
					</div>
				</div>
			</section>
		</main>
		<Footer />
		<Analytics />
		<SpeedInsights />
	</body>
</html>

<style>
	.logo-hero {
		filter: drop-shadow(0 0 10px rgba(232, 168, 76, 0.35));
	}

	.home-tagline {
		font-family: var(--font-display);
		font-style: italic;
		font-weight: 400;
		font-size: clamp(2rem, 4.8vw, 3.25rem);
		line-height: 1.1;
		letter-spacing: -0.015em;
		color: var(--color-text-primary);
		margin: 0;
	}

	.home-subtagline {
		font-family: var(--font-body);
		font-size: 1.0625rem;
		line-height: 1.55;
		color: var(--color-text-secondary);
		max-width: 36rem;
		margin: 1.5rem auto 0;
	}

	@media (min-width: 768px) {
		.home-subtagline {
			font-size: 1.1875rem;
		}
	}

	.home-manifesto {
		font-family: var(--font-body);
		font-size: 1.125rem;
		line-height: 1.65;
		color: var(--color-text-secondary);
		margin: 0;
	}

	@media (min-width: 768px) {
		.home-manifesto {
			font-size: 1.25rem;
		}
	}

	.home-manifesto-byline {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		letter-spacing: 0.04em;
		color: var(--color-text-tertiary);
		margin: 1.75rem 0 0;
	}

	.home-manifesto-byline a {
		color: var(--color-text-secondary);
		text-decoration: none;
		background-image: linear-gradient(var(--color-text-tertiary), var(--color-text-tertiary));
		background-size: 100% 1px;
		background-position: 0 100%;
		background-repeat: no-repeat;
		transition: color 0.25s var(--ease-standard), background-image 0.25s var(--ease-standard);
	}

	.home-manifesto-byline a:hover {
		color: var(--color-accent);
		background-image: linear-gradient(var(--color-accent), var(--color-accent));
	}

	.home-kicker {
		display: inline-block;
		font-family: var(--font-mono);
		font-size: 0.6875rem;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: var(--color-accent);
		margin-bottom: 1.25rem;
	}

	.home-latest-link {
		display: block;
		text-decoration: none;
		color: inherit;
	}

	.home-latest-title {
		font-family: var(--font-display);
		font-weight: 500;
		font-size: clamp(1.75rem, 3.6vw, 2.5rem);
		line-height: 1.15;
		letter-spacing: -0.015em;
		color: var(--color-text-primary);
		margin: 0;
		transition: color 0.25s var(--ease-standard);
	}

	.home-latest-link:hover .home-latest-title {
		color: var(--color-accent);
	}

	.home-latest-deck {
		font-family: var(--font-body);
		font-size: 1.0625rem;
		line-height: 1.55;
		color: var(--color-text-secondary);
		margin: 0.85rem 0 0;
	}

	@media (min-width: 768px) {
		.home-latest-deck {
			font-size: 1.125rem;
		}
	}

	.home-latest-meta {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		color: var(--color-text-tertiary);
		margin-top: 1rem;
	}

	.home-topics {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
	}

	.home-topic {
		margin: 0;
		border-top: 1px solid var(--color-border);
	}

	.home-topic:first-child {
		border-top: none;
	}

	.home-topic-link {
		display: grid;
		grid-template-columns: auto 1fr;
		column-gap: 1.25rem;
		align-items: baseline;
		padding: 1.5rem 0;
		text-decoration: none;
		color: inherit;
		transition: color 0.25s var(--ease-standard);
	}

	.home-topic-num {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		letter-spacing: 0.08em;
		color: var(--color-text-tertiary);
		padding-top: 0.35em;
		transition: color 0.25s var(--ease-standard);
	}

	.home-topic-link:hover .home-topic-num {
		color: var(--color-accent);
	}

	.home-topic-body {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	.home-topic-title {
		font-family: var(--font-display);
		font-weight: 500;
		font-size: 1.5rem;
		line-height: 1.2;
		letter-spacing: -0.01em;
		color: var(--color-text-primary);
		transition: color 0.25s var(--ease-standard);
	}

	.home-topic-link:hover .home-topic-title {
		color: var(--color-accent);
	}

	.home-topic-description {
		font-family: var(--font-body);
		font-size: 1rem;
		line-height: 1.55;
		color: var(--color-text-secondary);
	}

	.home-topic-count {
		font-family: var(--font-mono);
		font-size: 0.6875rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-text-tertiary);
		margin-top: 0.25rem;
	}

	.home-all-link {
		font-family: var(--font-mono);
		font-size: 0.8125rem;
		letter-spacing: 0.04em;
		color: var(--color-text-secondary);
		text-decoration: none;
		background-image: linear-gradient(var(--color-text-tertiary), var(--color-text-tertiary));
		background-size: 100% 1px;
		background-position: 0 100%;
		background-repeat: no-repeat;
		transition: color 0.25s var(--ease-standard), background-image 0.25s var(--ease-standard);
	}

	.home-all-link:hover {
		color: var(--color-accent);
		background-image: linear-gradient(var(--color-accent), var(--color-accent));
	}
</style>
