<!-- ABOUTME: Blog post layout with monospace title, meta line, tags, and centered prose content. -->
<!-- ABOUTME: Wraps individual blog posts with full HTML document, head, header, footer, and sticky TOC. -->
---
import { Image } from 'astro:assets';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TableOfContents from '../components/TableOfContents.astro';
import TagPill from '../components/TagPill.astro';

type RelatedPost = CollectionEntry<'blog'>;

interface Heading {
	depth: number;
	slug: string;
	text: string;
}

type PostData = CollectionEntry<'blog'>['data'];

interface Props extends PostData {
	slug: string;
	readingTime: number;
	relatedPosts: RelatedPost[];
	headings: Heading[];
}

const {
	title,
	description,
	pubDate,
	updatedDate,
	author,
	heroImage,
	tags,
	category,
	readingTime,
	headings = [],
} = Astro.props;
---

<html lang="en" data-theme="dark">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={heroImage}
			type="article"
			author={author}
			publishedTime={pubDate}
			modifiedTime={updatedDate}
			tags={tags}
			wordCount={readingTime * 180}
			articleSection={category}
		/>
		<style>
			.post-frame {
				max-width: 60rem;
				margin: 0 auto;
			}
			.post-header {
				max-width: 60rem;
				margin: 0 auto;
			}
			.post-toc-inline {
				max-width: 60rem;
				margin: 0 auto;
			}
			.post-hero {
				max-width: 52rem;
				margin: 0 auto;
			}
			.post-hero img {
				width: 100%;
				height: auto;
				border-radius: 8px;
			}
			.post-body {
				max-width: 60rem;
				margin: 0 auto;
			}
			.post-content {
				font-size: 1.1875rem;
				line-height: 1.8;
			}
			.toc-sidebar {
				display: none;
			}
			@media (max-width: 768px) {
				.post-content {
					font-size: 1.0625rem;
					line-height: 1.75;
				}
			}
			@media (min-width: 1440px) {
				.post-frame {
					max-width: none;
					width: 100%;
					padding-left: 2rem;
					padding-right: 2rem;
					display: grid;
					grid-template-columns: minmax(0, 1fr) minmax(0, 60rem) 14rem;
					gap: 3rem;
					align-items: start;
				}
				.post-frame > article {
					grid-column: 2;
				}
				.post-toc-inline {
					display: none;
				}
				.toc-sidebar {
					display: block;
					grid-column: 3;
					position: sticky;
					top: 6rem;
					width: 14rem;
					align-self: start;
				}
			}
		</style>
	</head>

	<body style="background-color: var(--color-bg);">
		<Header />
		<main>
			<div class="post-frame">
				<article>
					<header class="post-header px-5 pt-16 pb-8 sm:px-6 md:pt-28 md:pb-10">
						<h1 class="font-heading font-medium text-3xl md:text-[2.75rem] tracking-[-0.02em] leading-[1.15]" style="color: var(--color-text-primary);">
							{title}
						</h1>
						<div class="mt-4 flex flex-col gap-y-2 font-heading text-[0.8125rem] sm:flex-row sm:flex-wrap sm:items-center sm:gap-x-3 sm:gap-y-1" style="color: var(--color-text-tertiary);">
							<FormattedDate date={pubDate} />
							<span class="hidden sm:inline">&middot;</span>
							<span>{readingTime} min read</span>
							{updatedDate && (
								<>
									<span class="hidden sm:inline">&middot;</span>
									<span>
										updated {updatedDate.toISOString().split('T')[0]}
									</span>
								</>
							)}
						</div>
						{tags.length > 0 && (
							<div class="mt-4 flex w-full flex-wrap content-start items-start gap-4">
								{tags.map((tag: string) => (
									<TagPill tag={tag} />
								))}
							</div>
						)}
					</header>

					{headings.length > 0 && (
						<div class="post-toc-inline px-5 pb-8 sm:px-6">
							<TableOfContents headings={headings} variant="inline" />
						</div>
					)}

					{heroImage && (
						<div class="post-hero px-5 pb-8 sm:px-6">
							<Image
								width={832}
								height={468}
								src={heroImage}
								alt=""
							/>
						</div>
					)}

					<div class="post-body px-5 pb-14 sm:px-6 md:pb-16">
						<div class="prose post-content" data-pagefind-body>
							<slot />
						</div>
					</div>
				</article>
				<aside class="toc-sidebar">
					<TableOfContents headings={headings} />
				</aside>
			</div>
		</main>
		<Footer />
		<Analytics />
		<SpeedInsights />
		<script src="../scripts/balanced-headlines.ts"></script>
	</body>
</html>
